<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ComponentSpec isProfile="true" CMDVersion="1.2" CMDOriginalVersion="1.2" xsi:noNamespaceSchemaLocation="https://infra.clarin.eu/CMDI/1.x/xsd/cmd-component.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <Header>
        <ID>clarin.eu:cr1:p_1721373444013</ID>
        <Name>LCmeta</Name>
        <Description>Metadata for a Learner Corpus</Description>
        <Status>development</Status>
    </Header>
    <Component name="LCmeta" CardinalityMin="1" CardinalityMax="1">
        <Component name="Administrative_metadata" ComponentRef="clarin.eu:cr1:c_1721373444009" CardinalityMin="1" CardinalityMax="1">
            <Element name="corpus_name" ValueScheme="string" CardinalityMin="1" CardinalityMax="unbounded" cue:DisplayPriority="1" xmlns:cue="http://www.clarin.eu/cmd/cues/1">
                <Documentation>Full name of the corpus</Documentation>
            </Element>
            <Element name="corpus_acronym" ValueScheme="string" CardinalityMin="0" CardinalityMax="1">
                <Documentation>Corpus acronym</Documentation>
            </Element>
            <Element name="corpus_version" ValueScheme="string" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Corpus version</Documentation>
            </Element>
            <Element name="corpus_pid" ValueScheme="string" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Persistent identifier</Documentation>
            </Element>
            <Element name="corpus_cite_as" ValueScheme="string" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Corpus citation</Documentation>
            </Element>
            <Element name="corpus_ref_article" ValueScheme="string" CardinalityMin="0" CardinalityMax="unbounded">
                <Documentation>Reference article</Documentation>
            </Element>
            <Element name="corpus_description" ValueScheme="string" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Short description of the corpus</Documentation>
            </Element>
            <Element name="corpus_documentation" ValueScheme="anyURI" CardinalityMin="0" CardinalityMax="unbounded">
                <Documentation>Link to more extensive corpus documentation</Documentation>
            </Element>
            <Element name="corpus_author" ValueScheme="string" CardinalityMin="1" CardinalityMax="unbounded">
                <Documentation>Corpus creator</Documentation>
            </Element>
            <Element name="corpus_contributor" ValueScheme="string" CardinalityMin="0" CardinalityMax="unbounded">
                <Documentation>Corpus contributor</Documentation>
            </Element>
            <Element name="corpus_contact_mail" ValueScheme="string" CardinalityMin="1" CardinalityMax="unbounded">
                <Documentation>Contact e-mail address</Documentation>
            </Element>
            <Element name="corpus_publisher" ValueScheme="string" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Person or entity responsible for the corpus</Documentation>
            </Element>
            <Element name="corpus_availability" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Licensing terms and conditions</Documentation>
                <ValueScheme>
                    <Vocabulary>
                        <enumeration>
                            <item>open</item>
                            <item>restricted</item>
                            <item>closed</item>
                        </enumeration>
                    </Vocabulary>
                </ValueScheme>
            </Element>
            <Element name="corpus_access_requirements" ValueScheme="string" CardinalityMin="1" CardinalityMax="1" cue:lcr_availability="restricted" xmlns:cue="http://www.clarin.eu/cmd/cues/1">
                <Documentation>Access requirements</Documentation>
            </Element>
            <Element name="corpus_licence" ValueScheme="string" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Licence name</Documentation>
            </Element>
            <Element name="corpus_licence_url" ValueScheme="anyURI" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Link to licence text</Documentation>
            </Element>
            <Element name="corpus_date_of_publication" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Date of publication</Documentation>
                <ValueScheme>
                    <pattern>\d{4}(-\d{2}(-\d{2})?)?</pattern>
                </ValueScheme>
            </Element>
            <Element name="corpus_other_versions" ValueScheme="string" CardinalityMin="0" CardinalityMax="unbounded">
                <Documentation>Associated version</Documentation>
            </Element>
            <Element name="corpus_character_encoding" ValueScheme="string" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Character encoding</Documentation>
            </Element>
            <Element name="corpus_file_format" ValueScheme="string" CardinalityMin="1" CardinalityMax="unbounded"/>
            <Element name="corpus_file_format_specifications" ValueScheme="string" CardinalityMin="0" CardinalityMax="unbounded">
                <Documentation>File format specification</Documentation>
            </Element>
            <Component name="corpus_related_research_project" CardinalityMin="0" CardinalityMax="unbounded">
                <Documentation>Research project related to the corpus</Documentation>
                <Element name="corpus_related_research_project_name" ValueScheme="string" CardinalityMin="1" CardinalityMax="1" cue:DisplayPriority="1" xmlns:cue="http://www.clarin.eu/cmd/cues/1">
                    <Documentation>Name of the related research project</Documentation>
                </Element>
                <Element name="corpus_related_research_project_URL" ValueScheme="string" CardinalityMin="0" CardinalityMax="1">
                    <Documentation>URL to the project page of the related research project</Documentation>
                </Element>
            </Component>
        </Component>
        <Component name="Situational_and_task_characteristics" ComponentRef="clarin.eu:cr1:c_1721373443964" CardinalityMin="1" CardinalityMax="1">
            <Documentation>Add 0-N task components to corpus metadata, add exactly one reference to task/task component to text metadata if various tasks are provided within one corpus</Documentation>
            <Element name="situation_id" ValueScheme="string" CardinalityMin="1" CardinalityMax="1" cue:DisplayPriority="1" xmlns:cue="http://www.clarin.eu/cmd/cues/1">
                <Documentation>Unique identifier for the language situation</Documentation>
            </Element>
            <Element name="situation_participants_addressor" CardinalityMin="0" CardinalityMax="1">
                <Documentation>Number of addressors</Documentation>
                <ValueScheme>
                    <Vocabulary>
                        <enumeration>
                            <item>single</item>
                            <item>two</item>
                            <item>more than two</item>
                        </enumeration>
                    </Vocabulary>
                </ValueScheme>
            </Element>
            <Element name="situation_participants_addressee" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Number of addressees</Documentation>
                <ValueScheme>
                    <Vocabulary>
                        <enumeration>
                            <item>single</item>
                            <item>plural</item>
                            <item>un-enumerated</item>
                        </enumeration>
                    </Vocabulary>
                </ValueScheme>
            </Element>
            <Element name="situation_participants_addressee_type" CardinalityMin="0" CardinalityMax="unbounded" cue:lcrtask_ifaddresseenotsingle="only show if value for addressee is not &quot;single&quot;" xmlns:cue="http://www.clarin.eu/cmd/cues/1">
                <Documentation>Personal relationship with addressees</Documentation>
                <ValueScheme>
                    <Vocabulary>
                        <enumeration>
                            <item>classmates</item>
                            <item>student-teacher</item>
                            <item>colleagues</item>
                            <item>family members</item>
                            <item>friends</item>
                            <item>strangers</item>
                        </enumeration>
                    </Vocabulary>
                </ValueScheme>
            </Element>
            <Element name="situation_participants_onlookers" ValueScheme="boolean" CardinalityMin="0" CardinalityMax="1">
                <Documentation>Are there on-lookers?</Documentation>
            </Element>
            <Element name="situation_mode" CardinalityMin="1" CardinalityMax="unbounded">
                <Documentation>Mode</Documentation>
                <ValueScheme>
                    <Vocabulary>
                        <enumeration>
                            <item>speech</item>
                            <item>writing</item>
                            <item>signing</item>
                        </enumeration>
                    </Vocabulary>
                </ValueScheme>
            </Element>
            <Element name="situation_medium" CardinalityMin="1" CardinalityMax="unbounded">
                <Documentation>Medium of communication</Documentation>
                <ValueScheme>
                    <Vocabulary>
                        <enumeration>
                            <item>typed</item>
                            <item>handwritten</item>
                            <item>e-mail</item>
                            <item>text messaging (phone service)</item>
                            <item>instant messaging (online)</item>
                            <item>face-to-face</item>
                            <item>video conferencing</item>
                            <item>blogging</item>
                            <item>discussion forum</item>
                            <item>telephone</item>
                        </enumeration>
                    </Vocabulary>
                </ValueScheme>
            </Element>
            <Element name="situation_planning_type" CardinalityMin="0" CardinalityMax="1">
                <Documentation>Situation circumstances</Documentation>
                <ValueScheme>
                    <Vocabulary>
                        <enumeration>
                            <item AppInfo="">real time</item>
                            <item>planned</item>
                            <item>scripted</item>
                            <item>revised and edited</item>
                        </enumeration>
                    </Vocabulary>
                </ValueScheme>
            </Element>
            <Element name="situation_setting" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Situation settings</Documentation>
                <ValueScheme>
                    <Vocabulary>
                        <enumeration>
                            <item>personal</item>
                            <item>public</item>
                            <item>occupational</item>
                            <item>educational</item>
                        </enumeration>
                    </Vocabulary>
                </ValueScheme>
            </Element>
            <Element name="situation_purpose" ValueScheme="string" CardinalityMin="1" CardinalityMax="1">
                <Documentation>Communicative purpose</Documentation>
            </Element>
        </Component>
    </Component>
</ComponentSpec>
