<?xml version="1.0" encoding="UTF-8"?>
<ComponentSpec xmlns:clariah="http://www.clariah.eu/" xmlns:cue="http://www.clarin.eu/cmd/cues/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" isProfile="true" CMDVersion="1.2" CMDOriginalVersion="1.2" xsi:noNamespaceSchemaLocation="https://infra.clarin.eu/CMDI/1.x/xsd/cmd-component.xsd">
    <Header>
        <ID>clarin.eu:cr1:p_1721373444013</ID>
        <Name>LCmeta</Name>
        <Description>Metadata for a Learner Corpus</Description>
        <Status>development</Status>
    </Header>
    <Component name="LCmeta">
        <clariah:label xml:lang="en">Language Corpus metadata</clariah:label>
        <Component name="Administrative_metadata">
            <Element name="corpus_name">
                <Documentation>Full name of the corpus</Documentation>
            </Element>
            <Element name="corpus_acronym" cue:class="skosType">
                <clariah:autoCompleteURI>/proxy/skosmos/clavas/ISO639-3</clariah:autoCompleteURI>
                <Documentation>Corpus acronym</Documentation>
            </Element>
            <Element name="corpus_version">
                <Documentation>Corpus version</Documentation>
            </Element>
            <Element name="corpus_pid">
                <Documentation>Persistent identifier</Documentation>
            </Element>
            <Element name="corpus_cite_as">
                <Documentation>Corpus citation</Documentation>
            </Element>
            <Element name="corpus_ref_article">
                <Documentation>Reference article</Documentation>
            </Element>
            <Element name="corpus_description">
                <Documentation>Short description of the corpus</Documentation>
            </Element>
            <Element name="corpus_documentation">
                <Documentation>Link to more extensive corpus documentation</Documentation>
            </Element>
            <Element name="corpus_author">
                <Documentation>Corpus creator</Documentation>
            </Element>
            <Element name="corpus_contributor">
                <Documentation>Corpus contributor</Documentation>
            </Element>
            <Element name="corpus_contact_mail">
                <Documentation>Contact e-mail address</Documentation>
            </Element>
            <Element name="corpus_publisher">
                <Documentation>Person or entity responsible for the corpus</Documentation>
            </Element>
            <Element name="corpus_availability">
                <Documentation>Licensing terms and conditions</Documentation>
                
            </Element>
            <Element name="corpus_access_requirements">
                <Documentation>Access requirements</Documentation>
            </Element>
            <Element name="corpus_licence">
                <Documentation>Licence name</Documentation>
            </Element>
            <Element name="corpus_licence_url">
                <Documentation>Link to licence text</Documentation>
            </Element>
            <Element name="corpus_date_of_publication">
                <Documentation>Date of publication</Documentation>
                
            </Element>
            <Element name="corpus_other_versions">
                <Documentation>Associated version</Documentation>
            </Element>
            <Element name="corpus_character_encoding">
                <Documentation>Character encoding</Documentation>
            </Element>
            <Element name="corpus_file_format"><!--cues--></Element>
            <Element name="corpus_file_format_specifications">
                <Documentation>File format specification</Documentation>
            </Element>
            <Component name="corpus_related_research_project">
                <Documentation>Research project related to the corpus</Documentation>
                <Element name="corpus_related_research_project_name">
                    <Documentation>Name of the related research project</Documentation>
                </Element>
                <Element name="corpus_related_research_project_URL">
                    <Documentation>URL to the project page of the related research project</Documentation>
                </Element>
            </Component>
        </Component>
        <Component name="Situational_and_task_characteristics">
            <Documentation>Add 0-N task components to corpus metadata, add exactly one reference to task/task component to text metadata if various tasks are provided within one corpus</Documentation>
            <Element name="situation_id">
                <Documentation>Unique identifier for the language situation</Documentation>
            </Element>
            <Element name="situation_participants_addressor">
                <Documentation>Number of addressors</Documentation>
                
            </Element>
            <Element name="situation_participants_addressee">
                <Documentation>Number of addressees</Documentation>
                
            </Element>
            <Element name="situation_participants_addressee_type">
                <Documentation>Personal relationship with addressees</Documentation>
                
            </Element>
            <Element name="situation_participants_onlookers">
                <Documentation>Are there on-lookers?</Documentation>
            </Element>
            <Element name="situation_mode">
                <Documentation>Mode</Documentation>
                
            </Element>
            <Element name="situation_medium">
                <Documentation>Medium of communication</Documentation>
                
            </Element>
            <Element name="situation_planning_type">
                <Documentation>Situation circumstances</Documentation>
                
            </Element>
            <Element name="situation_setting">
                <Documentation>Situation settings</Documentation>
                
            </Element>
            <Element name="situation_purpose">
                <Documentation>Communicative purpose</Documentation>
            </Element>
        </Component>
    </Component>
</ComponentSpec>